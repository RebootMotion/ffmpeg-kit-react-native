{
  "name": "ffmpeg-kit-react-native",
  "version": "6.1.0",
  "description": "FFmpeg Kit for React Native",
  "main": "src/index",
  "types": "src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "scripts": {
    "test": "jest",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "android",
    "ffmpeg",
    "ffmpeg-kit",
    "ios"
  ],
  "repository": "https://github.com/RebootMotion/ffmpeg-kit-fork",
  "author": "ARTHENICA <open-source@arthenica.com> (https://www.arthenica.com)",
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/RebootMotion/ffmpeg-kit-fork/issues"
  },
  "homepage": "https://github.com/RebootMotion/ffmpeg-kit-fork",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.7.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@release-it/conventional-changelog": "^10.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.2.79",
    "commitlint": "^19.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "pod-install": "^0.2.2",
    "prettier": "^3.4.2",
    "react": "18.2.0",
    "react-native": "0.73.11",
    "release-it": "^19.0.6"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-native": "*"
  },
  "jest": {
    "preset": "react-native"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}",
      "requireBranch": "main",
      "requireCleanWorkingDir": false,
      "push": true
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true,
      "releaseName": "Release ${version}",
      "tokenRef": "GITHUB_TOKEN"
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        },
        "infile": "CHANGELOG.md"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native-community",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
